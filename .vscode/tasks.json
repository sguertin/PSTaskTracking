{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build",
            "type": "shell",
            "command": "${workspaceFolder}/build/Build-Module.ps1",
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "/usr/bin/pwsh",
                    "args": ["-NoProfile"]
                }
            },
            "windows": {
                "command": "${workspaceFolder}\\build\\Build-Module.ps1",
                "args": ["-Certificate", "My"],
                "options": {
                    "cwd": "${workspaceFolder}",
                    "shell": {
                        "executable": "pwsh",
                        "args": ["-NoProfile"]
                    }
                }
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Deploy",
            "type": "shell",
            "command": "${workspaceFolder}/build/Deploy-Module.ps1",
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "/usr/bin/pwsh",
                    "args": ["-NoProfile"]
                }
            },
            "windows": {
                "command": "${workspaceFolder}\\build\\Deploy-Module.ps1",
                "options": {
                    "cwd": "${workspaceFolder}",
                    "shell": {
                        "executable": "pwsh",
                        "args": ["-NoProfile"]
                    }
                }
            },
            "problemMatcher": []
        }
    ]
}
